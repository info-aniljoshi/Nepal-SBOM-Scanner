# Nepal SBOM Scanner — copy to .env and adjust for your environment

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false
APP_VERSION=1.0.0
HTTPS_ONLY=false

# Security (required for production)
SESSION_SECRET_KEY=replace_with_long_random_hex_or_openssl_rand_hex_32
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change_me_to_a_strong_password
MAX_UPLOAD_SIZE_MB=50
UPLOAD_RATE_LIMIT=5

# Database
DATABASE_PATH=nepal_sbom.db

# OSV (usually unchanged)
OSV_API_URL=https://api.osv.dev/v1/querybatch

# AI — set at least one for remediation / executive summary / auto-fix PR version hints
GROQ_API_KEY=
OPENAI_API_KEY=

# GitHub OAuth (optional — private repo scan + auto-fix PR)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Auto-fix PR: fallback when GitHub API default branch cannot be read
DEFAULT_GIT_BRANCH=main
